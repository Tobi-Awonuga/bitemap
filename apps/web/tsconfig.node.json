{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "strict": true,
    "outDir": "./.tsc",
    "tsBuildInfoFile": "./.tsc/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
