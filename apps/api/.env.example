DATABASE_URL=postgres://bitemap:bitemap@localhost:5432/bitemap
PORT=4000
JWT_SECRET=change_me_in_production
NODE_ENV=development
RUN_MIGRATIONS=true
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=
API_JSON_LIMIT=256kb

# SMTP (required in production for real password-reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BiteMap <no-reply@bitemap.app>

PLACES_PROVIDER=local
GOOGLE_MAPS_API_KEY=
PLACES_CACHE_TTL_MS=120000
PLACES_RATE_LIMIT_MAX=60
